# MongoDB → Kafka pipeline
# Copy to .env and fill in the values before running.

# ── MongoDB source ────────────────────────────────────────────────────────────
ETL_MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/
ETL_MONGO_DATABASE=mydb
ETL_MONGO_COLLECTION=orders

# ── Kafka destination ─────────────────────────────────────────────────────────
ETL_KAFKA_BROKERS=broker1:9092,broker2:9092
ETL_KAFKA_TOPIC=orders.events
ETL_KAFKA_CLIENT_ID=etl-mk
# ETL_KAFKA_SSL=false

# ── Source delegate (required to enable this pipeline) ────────────────────────
ETL_SOURCE_DELEGATE_FILE=/app/delegates/orders.mjs
# ETL_SOURCE_DELEGATE_KEY=etl-mk:delegate:source
# ETL_DELEGATE_TYPE=esm

# ── Dead-letter and retry ─────────────────────────────────────────────────────
# ETL_DLQ_TOPIC=orders.events-dlq
# ETL_RETRY_ATTEMPTS=3
# ETL_RETRY_DELAY_MS=1000

# ── Logging ───────────────────────────────────────────────────────────────────
KOZEN_LOG_LEVEL=INFO
KOZEN_LOG_TYPE=object
