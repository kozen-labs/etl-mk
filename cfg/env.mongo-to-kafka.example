# MK pipeline: MongoDB → Kafka
# Copy to .env and fill in the values before running.

# ── MongoDB source (change stream origin) ─────────────────────────────────────
ETL_MK_SOURCE_URI=mongodb+srv://user:pass@cluster.mongodb.net/
ETL_MK_SOURCE_DATABASE=mydb
ETL_MK_SOURCE_COLLECTION=orders

# ── Kafka destination ─────────────────────────────────────────────────────────
ETL_MK_DESTINATION_BROKERS=broker1:9092,broker2:9092
ETL_MK_DESTINATION_TOPIC=orders.events
# ETL_MK_DESTINATION_CLIENT_ID=etl-mk
# ETL_MK_DESTINATION_SSL=false

# ── MK delegate (required to enable this pipeline) ───────────────────────────
ETL_MK_DELEGATE_FILE=/app/delegates/orders.mjs
# ETL_MK_DELEGATE_KEY=etl-mk:delegate:source
# ETL_DELEGATE_TYPE=esm

# ── Dead-letter topic ─────────────────────────────────────────────────────────
# ETL_MK_DLQ_TOPIC=orders.events-dlq

# ── Logging ───────────────────────────────────────────────────────────────────
KOZEN_LOG_LEVEL=INFO
KOZEN_LOG_TYPE=object
