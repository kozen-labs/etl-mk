# KM pipeline: Kafka → MongoDB
# Copy to .env and fill in the values before running.

# ── Kafka source ──────────────────────────────────────────────────────────────
ETL_KM_SOURCE_BROKERS=broker1:9092,broker2:9092
ETL_KM_SOURCE_TOPIC=orders.events
# ETL_KM_SOURCE_GROUP_ID=etl-mk-group
# ETL_KM_SOURCE_CLIENT_ID=etl-km
# ETL_KM_SOURCE_SSL=false

# ── MongoDB destination ───────────────────────────────────────────────────────
ETL_KM_DESTINATION_URI=mongodb+srv://user:pass@cluster.mongodb.net/
ETL_KM_DESTINATION_DATABASE=mydb
ETL_KM_DESTINATION_COLLECTION=orders_archive
# ETL_KM_DESTINATION_WRITE_MODE=insert

# ── KM delegate (required to enable this pipeline) ───────────────────────────
ETL_KM_DELEGATE_FILE=/app/delegates/archive.mjs
# ETL_KM_DELEGATE_KEY=etl-mk:delegate:destination
# ETL_DELEGATE_TYPE=esm

# ── Dead-letter and retry ─────────────────────────────────────────────────────
# ETL_KM_DLQ_TOPIC=orders.events-dlq
# ETL_KM_RETRY_ATTEMPTS=3
# ETL_KM_RETRY_DELAY_MS=1000

# ── Logging ───────────────────────────────────────────────────────────────────
KOZEN_LOG_LEVEL=INFO
KOZEN_LOG_TYPE=object
