# Bidirectional MongoDB ↔ Kafka pipeline
# Copy to .env and fill in the values before running.
# Both delegates active: MK (MongoDB→Kafka) and KM (Kafka→MongoDB) run in parallel.
# Source and destination may be different MongoDB instances or Kafka clusters.

# ── MK: MongoDB source (change stream origin) ─────────────────────────────────
ETL_MK_SOURCE_URI=mongodb+srv://user:pass@source-cluster.mongodb.net/
ETL_MK_SOURCE_DATABASE=mydb
ETL_MK_SOURCE_COLLECTION=orders

# ── MK: Kafka destination ─────────────────────────────────────────────────────
ETL_MK_DESTINATION_BROKERS=broker1:9092,broker2:9092
ETL_MK_DESTINATION_TOPIC=orders.events
# ETL_MK_DESTINATION_CLIENT_ID=etl-mk
# ETL_MK_DESTINATION_SSL=false

# ── MK delegate (required to enable MongoDB→Kafka direction) ──────────────────
ETL_MK_DELEGATE_FILE=/app/delegates/orders.mjs
# ETL_MK_DELEGATE_KEY=etl-mk:delegate:source
# ETL_MK_DLQ_TOPIC=orders.events-dlq

# ── KM: Kafka source ──────────────────────────────────────────────────────────
ETL_KM_SOURCE_BROKERS=broker1:9092,broker2:9092
ETL_KM_SOURCE_TOPIC=orders.events
# ETL_KM_SOURCE_GROUP_ID=etl-mk-group
# ETL_KM_SOURCE_CLIENT_ID=etl-km
# ETL_KM_SOURCE_SSL=false

# ── KM: MongoDB destination ───────────────────────────────────────────────────
ETL_KM_DESTINATION_URI=mongodb+srv://user:pass@dest-cluster.mongodb.net/
ETL_KM_DESTINATION_DATABASE=archive
ETL_KM_DESTINATION_COLLECTION=orders_archive
# ETL_KM_DESTINATION_WRITE_MODE=insert

# ── KM delegate (required to enable Kafka→MongoDB direction) ──────────────────
ETL_KM_DELEGATE_FILE=/app/delegates/archive.mjs
# ETL_KM_DELEGATE_KEY=etl-mk:delegate:destination
# ETL_KM_DLQ_TOPIC=orders.events-dlq
# ETL_KM_RETRY_ATTEMPTS=3
# ETL_KM_RETRY_DELAY_MS=1000

# ── Common ────────────────────────────────────────────────────────────────────
# ETL_DELEGATE_TYPE=esm
KOZEN_LOG_LEVEL=INFO
KOZEN_LOG_TYPE=object
