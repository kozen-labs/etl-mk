{
  "etl-mk:kafka-producer": {
    "target": "KafkaProducerService",
    "type": "class",
    "lifetime": "transient",
    "path": "services",
    "dependencies": [
      { "key": "assistant", "target": "IoC",            "type": "ref" },
      { "key": "logger",    "target": "logger:service", "type": "ref" }
    ]
  },
  "etl-mk:kafka-consumer": {
    "target": "KafkaConsumerService",
    "type": "class",
    "lifetime": "transient",
    "path": "services",
    "dependencies": [
      { "key": "assistant", "target": "IoC",            "type": "ref" },
      { "key": "logger",    "target": "logger:service", "type": "ref" }
    ]
  },
  "etl-mk:mongo-writer": {
    "target": "MongoWriterService",
    "type": "class",
    "lifetime": "transient",
    "path": "services",
    "dependencies": [
      { "key": "assistant", "target": "IoC",            "type": "ref" },
      { "key": "logger",    "target": "logger:service", "type": "ref" }
    ]
  },
  "etl-mk:mongo-to-kafka": {
    "target": "MongoToKafkaService",
    "type": "class",
    "lifetime": "transient",
    "path": "services",
    "dependencies": [
      { "key": "assistant",        "target": "IoC",                   "type": "ref" },
      { "key": "logger",           "target": "logger:service",        "type": "ref" },
      { "key": "srvKafkaProducer", "target": "etl-mk:kafka-producer", "type": "ref" }
    ]
  },
  "etl-mk:kafka-to-mongo": {
    "target": "KafkaToMongoService",
    "type": "class",
    "lifetime": "transient",
    "path": "services",
    "dependencies": [
      { "key": "assistant",        "target": "IoC",                   "type": "ref" },
      { "key": "logger",           "target": "logger:service",        "type": "ref" },
      { "key": "srvKafkaConsumer", "target": "etl-mk:kafka-consumer", "type": "ref" },
      { "key": "srvKafkaProducer", "target": "etl-mk:kafka-producer", "type": "ref" },
      { "key": "srvMongoWriter",   "target": "etl-mk:mongo-writer",   "type": "ref" }
    ]
  },
  "etl-mk:pipeline": {
    "target": "EtlPipelineService",
    "type": "class",
    "lifetime": "transient",
    "path": "services",
    "dependencies": [
      { "key": "assistant",       "target": "IoC",                   "type": "ref" },
      { "key": "logger",          "target": "logger:service",        "type": "ref" },
      { "key": "srvMongoToKafka", "target": "etl-mk:mongo-to-kafka", "type": "ref" },
      { "key": "srvKafkaToMongo", "target": "etl-mk:kafka-to-mongo", "type": "ref" }
    ]
  }
}
