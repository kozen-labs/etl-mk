{
  "name": "@kozen/etl-mk",
  "version": "1.0.0",
  "description": "Bi-directional MongoDB ↔ Kafka ETL pipeline module for the Kozen framework",
  "homepage": "https://github.com/kozen-labs/etl-mk#readme",
  "bugs": {
    "url": "https://github.com/kozen-labs/etl-mk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kozen-labs/etl-mk.git"
  },
  "license": "ISC",
  "author": "",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/*",
    "cfg/config.json",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && npm run copy:assets",
    "copy:assets": "copyfiles -u 1 \"src/**/*.json\" \"src/**/*.txt\" dist/",
    "start": "npx kozen --config=cfg/config.json",
    "dev": "ts-node node_modules/@kozen/engine/dist/bin/kozen.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "peerDependencies": {
    "@kozen/engine": "^1.1.15"
  },
  "dependencies": {
    "@kozen/trigger": "^1.0.7",
    "kafkajs": "2.2.4"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "copyfiles": "^2.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
